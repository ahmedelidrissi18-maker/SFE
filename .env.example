# Runtime
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestion_stagiaires?schema=public"

# Auth secrets
NEXTAUTH_SECRET="change-me-in-production"
AUTH_SECRET=""
DEFAULT_USER_PASSWORD="Password123!"

# Two-factor authentication
TWO_FACTOR_ISSUER="Gestion des Stagiaires"
TWO_FACTOR_ENCRYPTION_SECRET=""

# Redis
# Local development can use false. Production should use true with a reachable Redis instance.
REDIS_ENABLED="false"
REDIS_URL="redis://localhost:6379"
REDIS_CHANNEL_PREFIX="gestion-stagiaires"
REDIS_CONNECT_TIMEOUT_MS="2000"

# Documents
DOCUMENT_STORAGE_DRIVER="local"
DOCUMENT_STORAGE_LOCAL_ROOT="storage/documents"

# Healthcheck
HEALTHCHECK_QUEUE_WARNING_THRESHOLD="20"
HEALTHCHECK_QUEUE_CRITICAL_THRESHOLD="100"

# GitHub integration
GITHUB_TOKEN=""
GITHUB_API_BASE_URL="https://api.github.com"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Login providers
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""
AUTH_GITHUB_CLIENT_ID=""
AUTH_GITHUB_CLIENT_SECRET=""

# Internal jobs
NOTIFICATIONS_PROCESSOR_SECRET=""

# E2E smoke tests
E2E_DEMO_EMAIL="admin@stagiaires.local"
E2E_DEMO_PASSWORD="Password123!"
